# Committed demo defaults (lowest precedence) so a fresh clone builds and
# develops against the emulator suite with zero setup. Real Firebase config
# goes in .env.local (gitignored), which overrides everything here.
# These are PUBLIC identifiers — security lives in the rules files.
NEXT_PUBLIC_FIREBASE_API_KEY=demo-api-key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=demo-the-quiz-game.firebaseapp.com
NEXT_PUBLIC_FIREBASE_DATABASE_URL=http://127.0.0.1:9000/?ns=demo-the-quiz-game-default-rtdb
NEXT_PUBLIC_FIREBASE_PROJECT_ID=demo-the-quiz-game
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=demo-the-quiz-game.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=000000000000
NEXT_PUBLIC_FIREBASE_APP_ID=1:000000000000:web:demo
NEXT_PUBLIC_FIREBASE_USE_EMULATORS=false
