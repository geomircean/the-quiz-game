{
  "hosting": {
    "public": "out",
    "ignore": ["firebase.json", "**/.*", "**/node_modules/**"]
  },
  "firestore": {
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  },
  "database": {
    "rules": "database.rules.json"
  },
  "functions": {
    "source": "functions",
    "runtime": "nodejs20",
    "predeploy": "npm --prefix \"$RESOURCE_DIR\" install"
  },
  "emulators": {
    "auth": { "host": "0.0.0.0", "port": 9099 },
    "firestore": { "host": "0.0.0.0", "port": 8181 },
    "database": { "host": "0.0.0.0", "port": 9000 },
    "functions": { "host": "0.0.0.0", "port": 5001 },
    "ui": { "enabled": true, "host": "0.0.0.0", "port": 4001 },
    "singleProjectMode": true
  }
}
